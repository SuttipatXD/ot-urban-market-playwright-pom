{
  "name": "ot-urban-market-playwright-pom",
  "version": "2.0.0",
  "description": "Playwright POM E2E automated tests for O.T. URBAN MARKET registration form",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "test:report": "playwright show-report",
    "test:chromium": "playwright test --project=chromium",
    "test:firefox": "playwright test --project=firefox",
    "test:mobile": "playwright test --project=mobile-chrome",
    "test:tc01": "playwright test --grep TC01",
    "codegen": "playwright codegen https://forms.office.com/r/bep9t0hFG4"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0"
  }
}
